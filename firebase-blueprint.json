{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["guest", "host", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "wishlist": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "Holiday home listing details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hostId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "pricePerNight": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "location": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "maxGuests": { "type": "number" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hostId", "title", "pricePerNight", "location"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Property rental booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "guestId": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "paymentIntentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "guestId", "checkIn", "checkOut", "totalPrice", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "User review for a property",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "userId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Real-time chat message between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application configurations",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "trn": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "currencyOfChoice": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "timezoneValue": { "type": "string" },
        "dateFormat": { "type": "string" },
        "availableCategories": { "type": "array", "items": { "type": "string" } },
        "availableAreas": { "type": "array", "items": { "type": "string" } },
        "availableAmenities": { "type": "array", "items": { "type": "string" } },
        "availableFurnishing": { "type": "array", "items": { "type": "string" } },
        "customBrandColor": { "type": "string" },
        "customFontFamily": { "type": "string" },
        "letterheadTitle": { "type": "string" },
        "letterheadSlogan": { "type": "string" },
        "letterheadWatermark": { "type": "string" },
        "letterheadSelectedTemplate": { "type": "string", "enum": ["modern", "minimalist", "classic"] },
        "letterheadLogoUrl": { "type": "string" },
        "letterheadImageUrl": { "type": "string" },
        "letterheadPageSize": { "type": "string" },
        "letterheadMarginTop": { "type": "number" },
        "letterheadMarginBottom": { "type": "number" },
        "letterheadMarginLeft": { "type": "number" },
        "letterheadMarginRight": { "type": "number" }
      }
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Lodge requests for maintenance, rent collection scheduling, or invoicing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userProfileRole": { "type": "string" },
        "propertyId": { "type": "string" },
        "propertyTitle": { "type": "string" },
        "category": { "type": "string", "enum": ["maintenance", "rent_collection", "invoice_query", "other"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "resolved"] },
        "scheduledDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "StaffMessage": {
      "title": "StaffMessage",
      "description": "Inner office real-time coordination chat messages available specifically to staff members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "StaffDM": {
      "title": "StaffDM",
      "description": "Direct message between staff and other members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "recipientId": { "type": "string" },
        "channelId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "senderRole", "recipientId", "channelId", "text"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "properties": { "schema": "Property", "description": "Property listings" },
    "bookings": { "schema": "Booking", "description": "Booking records" },
    "properties/{propertyId}/reviews": { "schema": "Review", "description": "Property reviews" },
    "chats": { "schema": "ChatMessage", "description": "Chat messages (grouped by chatId)" },
    "tickets": { "schema": "SupportTicket", "description": "Support tickets lodged by guests/landlords" },
    "staff_messages": { "schema": "StaffMessage", "description": "Coordination messages circulated among workspace staff roles" },
    "staff_dms": { "schema": "StaffDM", "description": "Direct messages between staff and other users" },
    "settings": { "schema": "Settings", "description": "Global system configurations" }
  }
}
